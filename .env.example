# Supabase browser/SSR configuration
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# TanStack Start auth middleware aliases
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Optional project metadata
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Never put DATAGOLF_API_KEY or SUPABASE_SERVICE_ROLE_KEY in VITE_* variables.
# Set DataGolf directly as a Supabase Edge Function secret:
# supabase secrets set DATAGOLF_API_KEY=your_key
